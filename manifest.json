{
  "manifest_version": 3,
  "name": "Quick Webpage Translate",
  "version": "1.0.0",
  "description": "One-click in-place translation — URL and links stay original. Recent & pinned languages, plus hover/select to reveal the source.",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": ["https://translate.googleapis.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.translate.goog/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick Webpage Translate",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
